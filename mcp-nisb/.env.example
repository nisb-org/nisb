# NISB backend environment template
# Copy this file to .env and fill in local secrets before deployment:
#   cp mcp-nisb/.env.example mcp-nisb/.env
#
# Never commit a filled .env file.
# Never commit real API keys, production secrets, or local-only values.

# ============================================================
# REQUIRED before production: change NISB_SECRET_KEY below.
# Generate a strong value, for example:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================================

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
# Used for embeddings. Also used by the OpenAI TTS room provider
# when text-to-speech generation is enabled.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Default voice for the OpenAI TTS room provider.
# Common values include: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_DEFAULT_VOICE=alloy

# ------------------------------------------------------------
# LLM providers
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# User system
# ------------------------------------------------------------
# Use a stable local user id for a single-user deployment.
# For production, replace this with your own non-secret stable id.
NISB_USER_ID=nisb_default_user

# Enable the NISB user system.
NISB_USER_SYSTEM_ENABLED=true

# Disable public registration by default.
NISB_REGISTRATION_ENABLED=false

# REQUIRED: replace change-me with a strong random value before production.
NISB_SECRET_KEY=change-me

# ------------------------------------------------------------
# External room/search/media providers
# ------------------------------------------------------------
# Optional; leave blank to disable the corresponding provider.

# Web search provider
SERPER_API_KEY=

# Stock photo/video provider
PEXELS_API_KEY=

# Neural/web search provider
EXA_API_KEY=

# Sound effects and audio search provider
FREESOUND_API_KEY=

# Stock image/video/audio provider
PIXABAY_API_KEY=
