# 使用标准 slim 镜像（预编译库，构建快 10 倍）
FROM python:3.11-slim

# ⭐ 安装系统依赖 + 中文字体 + CA 证书（解决 HTTPS 连接问题）
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    fonts-noto-cjk \
    fonts-wqy-zenhei \
    fontconfig \
    ca-certificates \
    && fc-cache -fv \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 库（使用预编译 wheel）
RUN pip install --no-cache-dir \
    numpy==1.24.3 \
    pandas==2.0.3 \
    matplotlib==3.8.0 \
    networkx==3.1 \
    requests==2.32.3 \
    httpx==0.27.2 \
    beautifulsoup4==4.12.3 \
    lxml==5.3.0 \
    openai>=1.0.0 \
    anthropic==0.39.0 \
    psutil==5.9.8

WORKDIR /workspace
CMD ["tail", "-f", "/dev/null"]
