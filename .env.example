# NISB Environment Configuration Example
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# ---------------------------------------------------------
# Deployment
# ---------------------------------------------------------

# Your public domain (e.g. nisb.example.com)
NISB_DOMAIN=your-domain.com

# Secret key for internal signing. Generate with: openssl rand -hex 32
NISB_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---------------------------------------------------------
# LLM Providers
# ---------------------------------------------------------

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ---------------------------------------------------------
# Optional: Search / RAG Providers
# ---------------------------------------------------------

# Serper (Google Search)
SERPER_API_KEY=

# Pexels (image search)
PEXELS_API_KEY=

# Exa (neural web search)
EXA_API_KEY=

# ---------------------------------------------------------
# Runtime
# ---------------------------------------------------------

# Path to persistent data directory on host
NISB_DATA_DIR=/opt/nisb-data

# Log level: debug | info | warning | error
LOG_LEVEL=info

# ---------------------------------------------------------
# Notes
# ---------------------------------------------------------
# For commercial licensing: license@nisb.me
# For remote install: install@nisb.me
# For general contact: contact@nisb.me
